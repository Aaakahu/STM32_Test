{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "make",
            "args": ["-j4"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Download (Flash Only)",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "C:/ProgramData/chocolatey/lib/openocd/tools/install/share/openocd/scripts/interface/stlink.cfg",
                "-f", "C:/ProgramData/chocolatey/lib/openocd/tools/install/share/openocd/scripts/target/stm32f1x.cfg",
                "-c", "program build/STM32_Test.elf verify reset exit"
            ],
            "group": "none",
            "problemMatcher": [],
            "dependsOn": "Build"  // 先自动编译，再烧录
        }
    ]
}